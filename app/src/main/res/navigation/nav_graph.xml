<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_steps">

    <!-- Main home / live step-counting screen -->
    <fragment
        android:id="@+id/nav_steps"
        android:name="com.example.goforitGit.feature.steps.ui.StepsFragment"
        android:label="Home"
        tools:layout="@layout/feature_steps_fragment" />

    <!-- Statistics screen -->
    <activity
        android:id="@+id/nav_statistics"
        android:name="com.example.goforitGit.feature.statistics.ui.StatisticsActivity"
        android:label="Statistics &amp; progress" />

    <!-- Map and walking-route planner -->
    <activity
        android:id="@+id/nav_map"
        android:name="com.example.goforitGit.feature.map.ui.MapAndRoutesActivity"
        android:label="Map &amp; routes" />

    <!-- Campus competition ranking -->
    <activity
        android:id="@+id/nav_leaderboard"
        android:name="com.example.goforitGit.feature.leaderboard.ui.LeaderboardActivity"
        android:label="Leaderboard" />

    <!-- User account and reminder preferences -->
    <activity
        android:id="@+id/nav_profile"
        android:name="com.example.goforitGit.feature.profile.ui.ProfileActivity"
        android:label="Profile" />

</navigation>