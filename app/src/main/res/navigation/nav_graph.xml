<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_steps">

    <!-- This is the default screen when the app opens -->
    <fragment
        android:id="@+id/nav_steps"
        android:name="com.example.goforitGit.feature.steps.ui.StepsFragment"
        android:label="Steps"
        tools:layout="@layout/feature_steps_fragment" />

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.goforitGit.feature.home.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_gallery"
        android:name="com.example.goforitGit.feature.gallery.ui.GalleryFragment"
        android:label="Gallery"
        tools:layout="@layout/fragment_gallery" />

    <fragment
        android:id="@+id/nav_slideshow"
        android:name="com.example.goforitGit.feature.slideshow.ui.SlideshowFragment"
        android:label="Slideshow"
        tools:layout="@layout/fragment_slideshow" />

</navigation>