<?xml version="1.0" encoding="utf-8"?>
<!--
  Two simple oval footprints stepping diagonally — upper-left foot and
  lower-right foot. Reliable cubic-bezier ovals so it renders the same
  on every Android version.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="20dp"
    android:height="20dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#7C39A0">

    <!-- Upper-left footprint -->
    <path
        android:fillColor="#000000"
        android:pathData="M7,3 c -1.66,0 -3,1.79 -3,4 v 2 c 0,2.21 1.34,4 3,4 s 3,-1.79 3,-4 v -2 c 0,-2.21 -1.34,-4 -3,-4 z" />

    <!-- Lower-right footprint -->
    <path
        android:fillColor="#000000"
        android:pathData="M17,11 c -1.66,0 -3,1.79 -3,4 v 2 c 0,2.21 1.34,4 3,4 s 3,-1.79 3,-4 v -2 c 0,-2.21 -1.34,-4 -3,-4 z" />

</vector>