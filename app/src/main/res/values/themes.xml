<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.GoForIt" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">#1F2A44</item>
        <item name="android:textColorHint">#7B8197</item>

        <item name="android:statusBarColor">#63ABEF</item>
    </style>

    <style name="QuietHourSliderLabel" parent="Widget.MaterialComponents.Tooltip">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#883FA8</item>
    </style>

    <style name="Theme.GoForIt.NoActionBar" parent="Theme.GoForIt">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.GoForIt.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.GoForIt.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="ProfileOutlinedInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#F4F1FB</item>
        <item name="boxStrokeColor">#7B8197</item>
        <item name="hintTextColor">#7B8197</item>
        <item name="android:textColorHint">#7B8197</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>
  <!-- Base application theme. -->
    <style name="Base.Theme.GoForIt" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

</resources>