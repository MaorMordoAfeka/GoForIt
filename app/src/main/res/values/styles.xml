<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================= -->
    <!--  Typography                                                   -->
    <!-- ============================================================= -->
    <style name="Text.GoForIt.Display" parent="">
        <item name="android:textColor">@color/text_purple_dark</item>
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Text.GoForIt.H1" parent="">
        <item name="android:textColor">@color/text_purple_dark</item>
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.GoForIt.Title" parent="">
        <item name="android:textColor">@color/text_purple_dark</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.GoForIt.Body" parent="">
        <item name="android:textColor">@color/text_purple_dark</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="Text.GoForIt.Caption" parent="">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <!-- ============================================================= -->
    <!--  Cards                                                        -->
    <!-- ============================================================= -->
    <style name="Card.GoForIt" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Card.GoForIt.Tile">
        <item name="cardCornerRadius">@dimen/radius_tile</item>
    </style>

    <style name="Card.GoForIt.Positive">
        <item name="cardBackgroundColor">@color/soft_mint</item>
        <item name="strokeColor">@android:color/transparent</item>
    </style>

    <!-- ============================================================= -->
    <!--  Buttons                                                      -->
    <!--  Primary  = mint (high-emphasis CTA)                          -->
    <!--  Secondary= tonal/outlined purple                            -->
    <!--  Destruct = outlined error, clearly separated                 -->
    <!-- ============================================================= -->
    <style name="Button.GoForIt.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="backgroundTint">@color/brand_mint</item>
        <item name="android:textColor">@color/on_mint</item>
        <item name="iconTint">@color/on_mint</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="iconPadding">10dp</item>
        <item name="rippleColor">#3313351F</item>
    </style>

    <style name="Button.GoForIt.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height_secondary</item>
        <item name="android:textColor">@color/brand_purple</item>
        <item name="iconTint">@color/brand_purple</item>
        <item name="strokeColor">@color/brand_purple</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="rippleColor">#22563078</item>
    </style>

    <style name="Button.GoForIt.Tonal" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_height">@dimen/button_height_secondary</item>
        <item name="backgroundTint">@color/soft_lavender</item>
        <item name="android:textColor">@color/brand_purple_deep</item>
        <item name="iconTint">@color/brand_purple_deep</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_button</item>
    </style>

    <style name="Button.GoForIt.Destructive" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height_secondary</item>
        <item name="android:textColor">@color/status_error</item>
        <item name="iconTint">@color/status_error</item>
        <item name="strokeColor">@color/status_error</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_button</item>
    </style>

    <!-- ============================================================= -->
    <!--  Inputs                                                       -->
    <!-- ============================================================= -->
    <style name="Input.GoForIt" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/soft_lavender</item>
        <item name="boxStrokeColor">@color/brand_purple</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_input</item>
        <item name="hintTextColor">@color/brand_purple</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <!-- ============================================================= -->
    <!--  Toolbar                                                      -->
    <!-- ============================================================= -->
    <style name="Toolbar.GoForIt" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="titleTextColor">@color/text_purple_dark</item>
        <item name="navigationIconTint">@color/brand_purple_deep</item>
        <item name="android:minHeight">?attr/actionBarSize</item>
    </style>

    <!-- ============================================================= -->
    <!--  Sliders                                                      -->
    <!-- ============================================================= -->
    <style name="GoForItSliderLabel" parent="Widget.MaterialComponents.Tooltip">
        <item name="android:background">@drawable/bg_slider_value_popup</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="GoForItMintSliderLabel" parent="Widget.MaterialComponents.Tooltip">
        <item name="android:background">@drawable/bg_slider_value_popup_mint</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

</resources>