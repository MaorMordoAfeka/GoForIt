<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr">
    <!--   Map always full-screen   -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    <!--  Top app bar: consistent with Profile, Statistics, and Leaderboard.  -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#F7F9F3"
        android:elevation="6dp"
        android:theme="@style/ThemeOverlay.MaterialComponents.Light"
        app:navigationContentDescription="Open navigation menu"
        app:navigationIcon="@drawable/ic_menu_hamburger"
        app:navigationIconTint="@color/brand_purple_deep"
        app:title="Map and routes"
        app:titleTextColor="@color/text_purple_dark" />
    <!--   "You are here" walking figure. Positioned in code at the GPS point;
                 the feet dot marks the exact spot, the figure walks in place above it.   -->
    <FrameLayout
        android:id="@+id/walkingFigureContainer"
        android:layout_width="60dp"
        android:layout_height="78dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <ImageView
            android:id="@+id/walkingFigure"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="12dp"
            android:contentDescription="Your current location"
            android:src="@drawable/ic_mode_walking"
            app:tint="@color/brand_purple_deep" />

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|center_horizontal"
            android:background="@drawable/bg_location_dot" />
    </FrameLayout>
    <!--   Bottom sheet   -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/routeSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sheet_top"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.45"
        app:behavior_hideable="true"
        app:behavior_peekHeight="190dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!--   Drag handle   -->
            <View
                android:layout_width="44dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:background="@color/divider" />
            <!--   Start   -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/startInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#FFFFFF"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:endIconMode="clear_text"
                app:endIconTint="@color/text_muted"
                app:hintEnabled="false">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:completionThreshold="2"
                    android:ellipsize="end"
                    android:hint="Start — type a place or address"
                    android:inputType="text"
                    android:maxLines="1"
                    android:minHeight="84dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp"
                    android:singleLine="true"
                    android:textColor="@color/text_purple_dark"
                    android:textColorHint="@color/text_muted"
                    android:textSize="18sp" />
            </com.google.android.material.textfield.TextInputLayout>
            <!--   Destination   -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/destinationInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:boxBackgroundColor="#FFFFFF"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:endIconMode="clear_text"
                app:endIconTint="@color/text_muted"
                app:hintEnabled="false">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etDest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:completionThreshold="2"
                    android:ellipsize="end"
                    android:hint="Destination — type a place or address"
                    android:inputType="text"
                    android:maxLines="1"
                    android:minHeight="84dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp"
                    android:singleLine="true"
                    android:textColor="@color/text_purple_dark"
                    android:textColorHint="@color/text_muted"
                    android:textSize="18sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Parks and beaches"
                android:textColor="@color/text_purple_dark" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sParks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp"
                android:stepSize="0.1"
                android:value="0.5"
                android:valueFrom="0"
                android:valueTo="1"
                app:haloColor="@color/soft_lavender"
                app:haloRadius="20dp"
                app:labelBehavior="floating"
                app:thumbColor="@color/brand_purple"
                app:thumbRadius="12dp"
                app:tickColorActive="@color/brand_purple"
                app:tickColorInactive="@color/soft_lavender"
                app:tickRadiusActive="2dp"
                app:tickRadiusInactive="2dp"
                app:tickVisible="true"
                app:trackColorActive="@color/brand_purple"
                app:trackColorInactive="@color/soft_lavender"
                app:trackHeight="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Residential streets"
                android:textColor="@color/text_purple_dark" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sResidential"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp"
                android:stepSize="0.1"
                android:value="0.5"
                android:valueFrom="0"
                android:valueTo="1"
                app:haloColor="@color/soft_lavender"
                app:haloRadius="20dp"
                app:labelBehavior="floating"
                app:thumbColor="@color/brand_purple"
                app:thumbRadius="12dp"
                app:tickColorActive="@color/brand_purple"
                app:tickColorInactive="@color/soft_lavender"
                app:tickRadiusActive="2dp"
                app:tickRadiusInactive="2dp"
                app:tickVisible="true"
                app:trackColorActive="@color/brand_purple"
                app:trackColorInactive="@color/soft_lavender"
                app:trackHeight="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Lively areas"
                android:textColor="@color/text_purple_dark" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sBusy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp"
                android:stepSize="0.1"
                android:value="0.5"
                android:valueFrom="0"
                android:valueTo="1"
                app:haloColor="@color/soft_lavender"
                app:haloRadius="20dp"
                app:labelBehavior="floating"
                app:thumbColor="@color/brand_purple"
                app:thumbRadius="12dp"
                app:tickColorActive="@color/brand_purple"
                app:tickColorInactive="@color/soft_lavender"
                app:tickRadiusActive="2dp"
                app:tickRadiusInactive="2dp"
                app:tickVisible="true"
                app:trackColorActive="@color/brand_purple"
                app:trackColorInactive="@color/soft_lavender"
                app:trackHeight="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Extra distance budget (km)"
                android:textColor="@color/text_purple_dark" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sDistanceKm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp"
                android:stepSize="0.5"
                android:value="2"
                android:valueFrom="0"
                android:valueTo="10"
                app:haloColor="@color/soft_mint"
                app:haloRadius="20dp"
                app:labelBehavior="floating"
                app:thumbColor="@color/brand_mint"
                app:thumbRadius="12dp"
                app:tickColorActive="@color/brand_mint"
                app:tickColorInactive="@color/soft_mint"
                app:tickRadiusActive="2dp"
                app:tickRadiusInactive="2dp"
                app:tickVisible="true"
                app:trackColorActive="@color/brand_mint"
                app:trackColorInactive="@color/soft_mint"
                app:trackHeight="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Plan walking route"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/brand_purple"
                app:cornerRadius="28dp" />

            <TextView
                android:id="@+id/tvHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Status: idle"
                android:textColor="@color/text_muted" />
            <!--   Developer tools (diagnostics, not for regular users)   -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:background="@color/divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.06"
                android:text="Diagnostical tools for the route"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold" />
            <!--   Row 1: Show H3 + Clear   -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShowH3"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Show H3 Hexagons"
                    android:textColor="@color/brand_purple_deep"
                    android:textSize="11sp"
                    app:backgroundTint="@color/soft_lavender" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearH3"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Clear Overlays"
                    android:textColor="@color/brand_purple_deep"
                    android:textSize="11sp"
                    app:backgroundTint="@color/soft_lavender" />
            </LinearLayout>
            <!--   Row 2: Show POIs   -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShowPoi"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Show Points Of Interest (route reason)"
                android:textColor="@color/brand_purple_deep"
                android:textSize="11sp"
                app:backgroundTint="@color/soft_lavender" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <!--   Compass — custom 56dp control, matching the normal FAB size   -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnCompass"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="338dp"
        android:clickable="true"
        android:contentDescription="Reset map north"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:cardBackgroundColor="@color/soft_lavender"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardUseCompatPadding="false"
        app:layout_anchor="@id/mapView"
        app:layout_anchorGravity="bottom|end">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/ic_map_compass" />
    </com.google.android.material.card.MaterialCardView>
    <!--   Route options — secondary action   -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="270dp"
        android:contentDescription="Route options"
        app:backgroundTint="@color/soft_lavender"
        app:elevation="12dp"
        app:fabSize="normal"
        app:layout_anchor="@id/mapView"
        app:layout_anchorGravity="bottom|end"
        app:rippleColor="@color/soft_lavender"
        app:srcCompat="@drawable/ic_menu_sort_by_size"
        app:tint="@color/brand_purple_deep" />
    <!--   Center on my GPS location — primary action   -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="202dp"
        android:contentDescription="Center on my location"
        app:backgroundTint="@color/brand_purple_deep"
        app:elevation="12dp"
        app:fabSize="normal"
        app:layout_anchor="@id/mapView"
        app:layout_anchorGravity="bottom|end"
        app:rippleColor="@color/soft_lavender"
        app:srcCompat="@android:drawable/ic_menu_mylocation"
        app:tint="#FFFFFF" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>