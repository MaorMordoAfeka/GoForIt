<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:layoutDirection="ltr"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Toolbar.GoForIt"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationContentDescription="@string/pc_back"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/brand_purple_deep"
        app:title="@string/pc_screen_title"
        app:titleTextColor="@color/text_purple_dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_gutter"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!--  Loading  -->
            <LinearLayout
                android:id="@+id/loadingBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/brand_purple" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/pc_loading"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <!--  Error  -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/errorBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/radius_tile"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pc_error_generic"
                        android:textColor="@color/text_purple_dark"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRetry"
                        style="@style/Button.GoForIt.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/pc_retry" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--  Offline / stale banner  -->
            <TextView
                android:id="@+id/staleBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_status_pill_brand_mint"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="@string/pc_offline_cached"
                android:textColor="@color/text_purple_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!--  Active challenge  -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/activeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!--  Title row  -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="@color/soft_lavender"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivActiveIcon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_trending_up"
                                app:tint="@color/brand_purple" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="13dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvActiveTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pc_baseline_title"
                                android:textColor="@color/text_purple_dark"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvActiveReward"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/brand_mint_strong"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="Reward: +200 bonus points" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvActiveStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_pill"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="@string/pc_status_active"
                            android:textColor="@color/surface_white"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTimeRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        tools:text="Time left today: 06:12:44" />

                    <!--  Baseline / study-break progress  -->
                    <LinearLayout
                        android:id="@+id/activeProgressBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvActiveProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_purple_dark"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="320 / 800 verified steps" />

                        <ProgressBar
                            android:id="@+id/pbActive"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_mint" />
                    </LinearLayout>

                    <!--  Campus Explorer progress  -->
                    <LinearLayout
                        android:id="@+id/campusProgressBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvCampusSteps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:textColor="@color/text_purple_dark"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Steps: 900 / 1,200" />

                        <ProgressBar
                            android:id="@+id/pbCampusSteps"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_mint" />
                    </LinearLayout>

                    <!--  Completed  -->
                    <LinearLayout
                        android:id="@+id/completedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivCompletedCheck"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/status_ok" />

                        <TextView
                            android:id="@+id/tvCompletedReward"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_purple_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="+200 bonus points added to today's score" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--  Offers  -->
            <LinearLayout
                android:id="@+id/offersBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Today's challenges"
                    android:textColor="@color/text_purple_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Choose one goal for today and earn bonus points.\n It locks in for the day"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    tools:ignore="HardcodedText" />

                <!--  Raise Your Baseline  -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBaseline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="@dimen/radius_tile"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                app:cardBackgroundColor="@color/soft_lavender"
                                app:cardCornerRadius="21dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="21dp"
                                    android:layout_height="21dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_trending_up"
                                    app:tint="@color/brand_purple" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="13dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pc_baseline_title"
                                    android:textColor="@color/text_purple_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/pc_baseline_desc"
                                    android:textColor="@color/text_muted"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBaselineInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            tools:text="Your 7-day baseline: 6,200 steps" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupBaseline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:chipSpacingHorizontal="8dp"
                            app:chipSpacingVertical="10dp"
                            app:selectionRequired="false"
                            app:singleLine="false"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipEasy"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/pc_baseline_easy"
                                android:textColor="@color/text_purple_dark"
                                app:checkedIconTint="@color/brand_purple"
                                app:chipBackgroundColor="@color/soft_lavender"
                                app:chipStrokeColor="@color/divider"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipMedium"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/pc_baseline_medium"
                                android:textColor="@color/text_purple_dark"
                                app:checkedIconTint="@color/brand_purple"
                                app:chipBackgroundColor="@color/soft_lavender"
                                app:chipStrokeColor="@color/divider"
                                app:chipStrokeWidth="1dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipHard"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/pc_baseline_hard"
                                android:textColor="@color/text_purple_dark"
                                app:checkedIconTint="@color/brand_purple"
                                app:chipBackgroundColor="@color/soft_lavender"
                                app:chipStrokeColor="@color/divider"
                                app:chipStrokeWidth="1dp" />
                        </com.google.android.material.chip.ChipGroup>

                        <TextView
                            android:id="@+id/tvBaselineTarget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/pc_baseline_target_hint"
                            android:textColor="@color/text_purple_dark"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartBaseline"
                            style="@style/Button.GoForIt.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/pc_start_challenge" />

                        <TextView
                            android:id="@+id/tvBaselineUnavailable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/status_warn"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="Not enough history yet." />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!--  Study-Break Boost  -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStudyBreak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="@dimen/radius_tile"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                app:cardBackgroundColor="@color/soft_lavender"
                                app:cardCornerRadius="21dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="21dp"
                                    android:layout_height="21dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_study_break"
                                    app:tint="@color/brand_purple" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="13dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pc_study_title"
                                    android:textColor="@color/text_purple_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/pc_study_desc"
                                    android:textColor="@color/text_muted"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStudyWindow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:textColor="@color/text_purple_dark"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Your focus window: 14:00–18:00" />

                        <TextView
                            android:id="@+id/tvStudyGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            tools:text="Walk 800 verified steps during this window" />

                        <TextView
                            android:id="@+id/tvStudyReward"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/brand_mint_strong"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Reward: +200 bonus points" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartStudy"
                            style="@style/Button.GoForIt.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/pc_start_challenge" />

                        <TextView
                            android:id="@+id/tvStudyUnavailable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/status_warn"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="Not enough history yet." />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!--  Campus Explorer  -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCampus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="@dimen/radius_tile"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                app:cardBackgroundColor="@color/soft_lavender"
                                app:cardCornerRadius="21dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="21dp"
                                    android:layout_height="21dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_route"
                                    app:tint="@color/brand_purple" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="13dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pc_campus_title"
                                    android:textColor="@color/text_purple_dark"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/pc_campus_desc"
                                    android:textColor="@color/text_muted"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginEnd="8dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_footprints"
                                app:tint="@color/brand_purple" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pc_campus_req_steps"
                                android:textColor="@color/text_purple_dark"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCampusReward"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/brand_mint_strong"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Reward: +200 bonus points" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartCampus"
                            style="@style/Button.GoForIt.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/pc_start_challenge" />

                        <TextView
                            android:id="@+id/tvCampusUnavailable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/status_warn"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="Already claimed for today." />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>