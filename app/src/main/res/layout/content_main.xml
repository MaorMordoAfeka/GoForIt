<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:showIn="@layout/app_bar_main">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#121212"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="24dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/sensorsReadings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="60dp"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Steps: 0"
                    android:textColor="#EDEDED"
                    android:textSize="20sp" />

                <!-- emaHz centered -->
                <TextView
                    android:id="@+id/hzText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="emaHz: 0.000"
                    android:textColor="#EDEDED"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/modeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="current mode: UNKNOWN"
                    android:textColor="#EDEDED"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/spmText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="SPM: 0"
                    android:textColor="#EDEDED"
                    android:textSize="18sp" />
            </LinearLayout>

            <!--  Stats and apiTest panel  -->
            <LinearLayout
                android:id="@+id/apiTestPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="90dp"
                android:layoutDirection="ltr"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/kmhAndMapBtnPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layoutDirection="ltr"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/mapAndRoutesBtn"
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:backgroundTint="#CFA7FF"
                        android:text="open routes and map screen"
                        android:textAllCaps="true"
                        android:textColor="#000000" />

                    <Space
                        android:layout_width="40dp"
                        android:layout_height="85dp" />

                    <TextView
                        android:id="@+id/KmH"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center_vertical"
                        android:text="Current Km/H: 0.0"
                        android:textColor="#EDEDED"
                        android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/durMinutesInput"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:hint="Duration (minutes)"
                        android:inputType="number"
                        android:textColor="#EDEDED"
                        android:textColorHint="#9E9E9E" />

                    <Button
                        android:id="@+id/queryDurationBtn"
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:backgroundTint="#CFA7FF"
                        android:text="QUERY"
                        android:textAllCaps="true"
                        android:textColor="#000000" />
                </LinearLayout>

                <TextView
                    android:id="@+id/avgCadenceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Avg steps per duration:"
                    android:textColor="#EDEDED"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/avgCadenceVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="#EDEDED"
                    android:textSize="16sp" />

                <!-- Today total steps -->
                <TextView
                    android:id="@+id/todayStepsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Today's steps:"
                    android:textColor="#EDEDED"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/todayStepsVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="#EDEDED"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/lastDurStepsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Steps within that Duration:"
                    android:textColor="#EDEDED"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/lastDurStepsVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="#EDEDED"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
