{
  "version": 8,
  "name": "Offline Shortbread (Localhost)",
  "glyphs": "asset://glyphs/{fontstack}/{range}.pbf",
  "sources": {
    "local": {
      "type": "vector",
      "tiles": ["http://127.0.0.1:8080/tiles/{z}/{x}/{y}.pbf"],
      "minzoom": 0,
      "maxzoom": 14
    }
  },
  "layers": [
    { "id": "background", "type": "background", "paint": { "background-color": "#f0f4f8" } },
    {
      "id": "ocean",
      "type": "fill",
      "source": "local",
      "source-layer": "ocean",
      "paint": { "fill-color": "#8ecae6", "fill-opacity": 1.0 }
    },
    {
      "id": "land",
      "type": "fill",
      "source": "local",
      "source-layer": "land",
      "paint": { "fill-color": "#83de8a", "fill-opacity": 0.9 }
    },

    {
      "id": "water",
      "type": "fill",
      "source": "local",
      "source-layer": "water_polygons",
      "paint": { "fill-color": "#4fc3f7", "fill-opacity": 0.9 }
    },

    {
      "id": "water-lines",
      "type": "line",
      "source": "local",
      "source-layer": "water_lines",
      "paint": { "line-color": "#29b6f6", "line-width": 1 }
    },

    {
      "id": "boundaries",
      "type": "line",
      "source": "local",
      "source-layer": "boundaries",
      "paint": { "line-color": "#90a4ae", "line-width": 1, "line-opacity": 0.6 }
    },
    {
      "id": "sites",
      "type": "fill",
      "source": "local",
      "source-layer": "sites",
      "paint": { "fill-color": "#b7e4c7", "fill-opacity": 0.6 }
    },
    {
      "id": "streets",
      "type": "line",
      "source": "local",
      "source-layer": "streets",
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "stops": [[12, 1], [16, 6]] }
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "local",
      "source-layer": "buildings",
      "minzoom": 13,
      "paint": { "fill-color": "#d7ccc8", "fill-opacity": 0.6 }
    },

    {
      "id": "street-labels",
      "type": "symbol",
      "source": "local",
      "source-layer": "street_labels",
      "minzoom": 14,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "symbol-placement": "line",
        "text-max-angle": 45
      },
      "paint": {
        "text-color": "#000000",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "local",
      "source-layer": "place_labels",
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Medium"],
        "text-size": [
          "match", ["get", "kind"],
          ["city", "town"], 15,
          ["suburb", "neighbourhood", "quarter"], 12,
          10
        ],
        "text-transform": "none"
      },
      "paint": {
        "text-color": "#000000",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}
