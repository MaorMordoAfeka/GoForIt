rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid); // you can tighten later (block server fields)

      match /step_sessions/{doc} {
        allow read, write: if isOwner(uid);
      }

      match /bonus_visits/{doc} {
        allow read, write: if isOwner(uid);
      }

      match /daily/{doc} {
        allow read: if isOwner(uid);
        allow write: if false; // server-only (recommended)
      }

      match /daily_summaries/{doc} {
        allow read: if isOwner(uid);
        allow write: if false; // server-only
      }

      match /fcm_tokens/{token} {
        allow read, write: if isOwner(uid);
      }

      // Multi-device concurrent login detection. Server-only: the client
      // never writes this directly, only through the checkDeviceTrust /
      // releaseDeviceTrust callables. This is deliberate — if a client could
      // write its own trustedDeviceId, it could let a second device in
      // simply by overwriting the record.
      match /security/{docId} {
        allow read: if isOwner(uid);
        allow write: if false; // server-only
      }
    }

    match /bonus_stations/{stationId} {
      allow read: if true;
      allow write: if false; // admin only
    }

    match /leaderboards_daily/{dayKey}/entries/{uid} {
      allow read: if true;
      allow write: if false; // server-only
    }

    match /notification_jobs/{jobId} {
      allow read, write: if false; // server-only
    }
  }
}
